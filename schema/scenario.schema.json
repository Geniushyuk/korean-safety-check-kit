{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Geniushyuk/korean-safety-check-kit/schema/scenario.schema.json",
  "title": "Korean Safety Check Scenario",
  "type": "object",
  "required": ["id", "title", "subtitle", "category", "introCopy", "questions", "resultLevels", "recommendedActions", "officialResources", "disclaimer"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 2 },
    "subtitle": { "type": "string", "minLength": 2 },
    "category": { "type": "string", "minLength": 2 },
    "estimatedTime": { "type": "string" },
    "introCopy": { "type": "string", "minLength": 10 },
    "disclaimer": { "type": "string", "minLength": 10 },
    "questions": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "text", "helpText", "category", "weight", "options"],
        "properties": {
          "id": { "type": "string", "minLength": 2 },
          "text": { "type": "string", "minLength": 5 },
          "helpText": { "type": "string", "minLength": 5 },
          "category": { "type": "string", "minLength": 2 },
          "weight": { "type": "number", "minimum": 0 },
          "options": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "object",
              "required": ["label", "value", "score"],
              "properties": {
                "label": { "type": "string" },
                "value": { "enum": ["yes", "no", "unknown"] },
                "score": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "resultLevels": { "type": "array", "minItems": 4 },
    "recommendedActions": { "type": "array", "minItems": 5, "items": { "type": "string" } },
    "shareTemplates": { "type": "array", "items": { "type": "string" } },
    "copyMessages": { "type": "array", "items": { "type": "string" } },
    "officialResources": { "type": "array", "minItems": 1 },
    "emergencyResources": { "type": "array" }
  }
}
